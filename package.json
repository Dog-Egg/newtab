{
  "name": "browser-tab-monorepo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:app": "pnpm --filter @browser-tab/app dev",
    "dev:app:web": "pnpm --filter @browser-tab/app dev:web",
    "dev:app:extension": "pnpm --filter @browser-tab/app dev:extension",
    "dev:site": "pnpm --filter @browser-tab/site dev",
    "build:app": "pnpm --filter @browser-tab/app build",
    "build:app:web": "pnpm --filter @browser-tab/app build:web",
    "build:app:extension": "pnpm --filter @browser-tab/app build:extension",
    "build:site": "pnpm --filter @browser-tab/site build",
    "preview:app": "pnpm --filter @browser-tab/app preview",
    "preview:site": "pnpm --filter @browser-tab/site preview",
    "typecheck": "pnpm --recursive typecheck",
    "format": "prettier --write .",
    "prepare": "husky || true"
  },
  "lint-staged": {
    "**/*": "prettier --write --ignore-unknown"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "3.9.4",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.8.0"
  },
  "packageManager": "pnpm@11.7.0"
}
