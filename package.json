{
  "name": "project",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:app": "pnpm --filter @project/app dev",
    "dev:app:web": "pnpm --filter @project/app dev:web",
    "dev:app:ext": "pnpm --filter @project/app dev:ext",
    "dev:site": "pnpm --filter @project/site dev",
    "dev:store-assets": "pnpm --filter @project/store-assets dev",
    "generate:store-assets": "pnpm --filter @project/store-assets generate",
    "setup:store-assets-browser": "pnpm --filter @project/store-assets setup:browser",
    "build:app": "pnpm --filter @project/app build",
    "build:app:web": "pnpm --filter @project/app build:web",
    "build:app:ext": "pnpm --filter @project/app build:ext",
    "build:site": "pnpm --filter @project/site build",
    "preview:app": "pnpm --filter @project/app preview",
    "preview:site": "pnpm --filter @project/site preview",
    "test": "pnpm --recursive test",
    "typecheck": "pnpm --recursive typecheck",
    "format": "prettier --write .",
    "prepare": "husky || true"
  },
  "lint-staged": {
    "**/*": "prettier --write --ignore-unknown"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "3.9.4",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.8.0"
  },
  "packageManager": "pnpm@11.7.0"
}
