{
  "name": "browser-tab-monorepo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:ext": "pnpm --filter @browser-tab/extension dev",
    "dev:web": "pnpm --filter @browser-tab/web dev",
    "build:ext": "pnpm --filter @browser-tab/extension build",
    "build:web": "pnpm --filter @browser-tab/web build",
    "preview:ext": "pnpm --filter @browser-tab/extension preview",
    "preview:web": "pnpm --filter @browser-tab/web preview",
    "format": "prettier --write .",
    "prepare": "husky || true"
  },
  "lint-staged": {
    "**/*": "prettier --write --ignore-unknown"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "3.9.4",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.8.0"
  },
  "packageManager": "pnpm@11.7.0"
}
