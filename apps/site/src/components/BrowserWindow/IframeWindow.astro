---
import BrowserWindow from "./index.astro";
import projectConfig from "../../../../../project.config.json";

const PRODUCT_NAME = projectConfig.product.name;

interface Props {
  url: string;
  title?: string;
  tabTitle?: string;
  scale?: number;
  loading?: "eager" | "lazy";
}

const {
  url,
  title = `Interactive ${PRODUCT_NAME} product demo`,
  tabTitle = "New Tab",
  scale = 1,
  loading = "eager",
} = Astro.props;

const iframeScale = Math.min(Math.max(scale, 0.1), 1);
const iframeSize = `${100 / iframeScale}%`;
---

<div>
  <BrowserWindow
    url={url}
    title={tabTitle}
    class="mx-auto w-[1120px] max-w-full rounded-2xl border-black/10 shadow-[0_28px_80px_rgba(35,28,20,0.14)]"
    bodyClass="overflow-hidden p-0"
  >
    <div class="relative aspect-[16/9] w-full overflow-hidden">
      <iframe
        src={url}
        title={title}
        loading={loading}
        class="absolute left-0 top-0 block border-0"
        style={`width: ${iframeSize}; height: ${iframeSize}; transform: scale(${iframeScale}); transform-origin: top left;`}
      ></iframe>
    </div>
  </BrowserWindow>
</div>
