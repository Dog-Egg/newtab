---
interface Props {
  url?: string;
  minHeight?: number | string;
  class?: string;
  bodyClass?: string;
}

const { minHeight, class: className, bodyClass } = Astro.props;

const minHeightValue =
  typeof minHeight === "number" ? `${minHeight}px` : minHeight;
---

<div
  class:list={[
    "mb-6 overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm",
    className,
  ]}
  style={minHeightValue ? `min-height: ${minHeightValue};` : undefined}
>
  <!-- header -->
  <div class="flex h-10 items-center overflow-hidden bg-[#f0f5f9]">
    <div class="flex h-8 shrink-0 items-center gap-1.5 px-4" aria-hidden="true">
      <span class="size-3 rounded-full border border-[#e53e57] bg-[#ff5960]"
      ></span>
      <span class="size-3 rounded-full border border-[#d9a100] bg-[#ffbe00]"
      ></span>
      <span class="size-3 rounded-full border border-[#22a44d] bg-[#31c95c]"
      ></span>
    </div>

    <!-- new tab -->
    <div class="relative h-full min-w-0 max-w-40 flex-1">
      <div
        class="absolute bottom-0 flex h-[34px] w-full items-center rounded-t-lg bg-white px-2.5 pb-2.5 pt-1"
      >
        <span
          class="pointer-events-none absolute -left-2 bottom-0 size-2 rounded-br-lg shadow-[4px_4px_0_4px_#fff]"
          aria-hidden="true"></span>
        <span
          class="pointer-events-none absolute -right-2 bottom-0 size-2 rounded-bl-lg shadow-[-4px_4px_0_4px_#fff]"
          aria-hidden="true"></span>

        <span
          class="ml-2 min-w-0 flex-1 truncate text-xs leading-4 text-[#202124]"
        >
          New Tab
        </span>

        <span
          class="ml-2 grid size-4 shrink-0 place-items-center text-[#202124]"
        >
          <svg
            class="size-3.5"
            viewBox="0 0 24 24"
            fill="none"
            aria-hidden="true"
          >
            <path
              d="M6 6l12 12M18 6 6 18"
              stroke="currentColor"
              stroke-linecap="round"
              stroke-width="2.5"></path>
          </svg>
        </span>
      </div>
    </div>

    <span class="ml-2 grid size-6 shrink-0 place-items-center text-[#3c4043]">
      <svg class="size-4" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path
          d="M12 5v14M5 12h14"
          stroke="currentColor"
          stroke-linecap="round"
          stroke-width="2.4"></path>
      </svg>
    </span>
  </div>

  <div class:list={["bg-white", bodyClass]}>
    <slot />
  </div>
</div>
