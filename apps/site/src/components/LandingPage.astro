---
import "../styles/global.css";
import IframeWindow from "./BrowserWindow/IframeWindow.astro";
import { translations, type Locale } from "../i18n/translations";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = translations[locale];
const isEnglish = locale === "en";
const languageUrl = isEnglish ? "/zh/" : "/";
const languageLabel = isEnglish ? "中文" : "English";

const placeholderUrl = "https://example.com";
const gridPaper =
  "bg-paper bg-[linear-gradient(rgba(30,30,30,.075)_1px,transparent_1px),linear-gradient(90deg,rgba(30,30,30,.075)_1px,transparent_1px)] bg-[size:56px_56px]";
const sectionKicker =
  "flex items-center gap-2.5 border-b border-line pb-4 font-mono text-[11px] uppercase tracking-[.12em] text-caption";
const buttonBase =
  "inline-flex min-h-[52px] items-center justify-center gap-2 rounded-full px-[22px] text-sm font-semibold transition hover:-translate-y-0.5";
---

<!doctype html>
<html lang={t.lang} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={t.description} />
    <meta name="theme-color" content="#ff4f24" />
    <link rel="canonical" href={isEnglish ? "/" : "/zh/"} />
    <link rel="alternate" hreflang="en" href="/" />
    <link rel="alternate" hreflang="zh-CN" href="/zh/" />
    <link rel="alternate" hreflang="x-default" href="/" />
    <title>{t.title}</title>
  </head>
  <body class="bg-paper text-ink m-0 font-sans antialiased">
    <header
      class="bg-paper/90 sticky top-0 z-50 grid h-[76px] grid-cols-[1fr_auto_1fr] items-center border-b border-black/10 px-[clamp(24px,6vw,96px)] backdrop-blur-2xl max-md:h-[66px] max-md:grid-cols-[1fr_auto] max-md:px-5"
    >
      <a
        class="inline-flex w-max items-center gap-3 font-bold tracking-[-.03em]"
        href="#top"
        aria-label={t.homeLabel}
      >
        <span
          class="bg-brand relative grid size-7 rotate-[8deg] place-items-center rounded-lg"
          aria-hidden="true"
        >
          <span
            class="absolute left-1.5 top-1.5 size-1.5 border-l-2 border-t-2 border-white"
          ></span><span
            class="absolute right-1.5 top-1.5 size-1.5 border-r-2 border-t-2 border-white"
          ></span><span
            class="absolute bottom-1.5 left-1.5 size-1.5 border-b-2 border-l-2 border-white"
          ></span><span
            class="absolute bottom-1.5 right-1.5 size-1.5 border-b-2 border-r-2 border-white"
          ></span>
        </span>
        <span>BrowserTab</span>
      </a>
      <nav
        class="flex gap-10 text-[13px] text-[#66625d] max-md:hidden"
        aria-label={t.navLabel}
      >
        <a class="hover:text-brand transition-colors" href="#features"
          >{t.nav.features}</a
        ><a class="hover:text-brand transition-colors" href="#demo"
          >{t.nav.demo}</a
        ><a class="hover:text-brand transition-colors" href="#opensource"
          >{t.nav.openSource}</a
        >
      </nav>
      <div class="flex items-center gap-4 justify-self-end max-sm:gap-2.5">
        <a
          class="hover:text-brand text-[13px] font-medium text-[#66625d] transition-colors"
          href={languageUrl}
          hreflang={isEnglish ? "zh-CN" : "en"}>{languageLabel}</a
        >
        <a
          class="bg-brand inline-flex gap-2 rounded-full px-5 py-3 text-[13px] font-semibold text-white transition hover:-translate-y-0.5 max-sm:px-3.5"
          href={placeholderUrl}
          >{t.nav.download} <span class="max-sm:hidden">↓</span></a
        >
      </div>
    </header>

    <main id="top">
      <section
        class:list={[
          gridPaper,
          "relative min-h-[930px] overflow-hidden px-6 pt-[74px] text-center max-md:min-h-[780px] max-md:pt-14 max-sm:min-h-[680px] max-sm:px-[15px]",
        ]}
      >
        <div
          class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_50%_30%,rgba(251,250,247,.2),rgba(251,250,247,.75)_63%)]"
        >
        </div>
        <div class="relative z-[2] mx-auto max-w-[930px]">
          <div
            class="text-caption inline-flex items-center gap-2 rounded-full border border-[#ddd9d2] bg-white/70 px-3.5 py-2 font-mono text-[11px] uppercase tracking-[.12em] shadow-[0_6px_22px_rgba(20,20,20,.04)]"
          >
            <span
              class="bg-brand size-1.5 rounded-full shadow-[0_0_0_4px_#ffebe4]"
            ></span>
            {t.hero.badge}
          </div>
          <h1
            class="my-7 text-[clamp(50px,6.2vw,94px)] font-normal leading-[.98] tracking-[-.065em]"
          >
            {t.hero.line1}<br /><em class="text-brand not-italic"
              >{t.hero.line2}</em
            >
          </h1>
          <p
            class="text-muted mx-auto max-w-[650px] text-[clamp(15px,1.25vw,18px)] leading-[1.75]"
          >
            {t.hero.description}
          </p>
          <div
            class="mt-8 flex justify-center gap-3 max-sm:mx-auto max-sm:max-w-[330px] max-sm:flex-col"
          >
            <a class:list={[buttonBase, "bg-ink text-white"]} href="#demo"
              >{t.hero.try} <span>↘</span></a
            >
            <a
              class:list={[
                buttonBase,
                "bg-brand text-white shadow-[0_10px_24px_rgba(255,79,36,.2)]",
              ]}
              href={placeholderUrl}>{t.hero.chrome} <span>→</span></a
            >
          </div>
          <div
            class="mt-[22px] flex items-center justify-center gap-3 text-[11px] text-[#98938d] max-sm:text-[9px]"
          >
            <span>{t.hero.benefits[0]}</span><i
              class="size-[3px] rounded-full bg-[#aaa59f]"></i><span
              >{t.hero.benefits[1]}</span
            ><i class="size-[3px] rounded-full bg-[#aaa59f]"></i><span
              >{t.hero.benefits[2]}</span
            >
          </div>
        </div>

        <div
          class="relative z-[3] mx-auto mt-[62px] w-[min(1120px,96vw)] scroll-mt-24 max-md:mt-12 max-sm:w-full"
          id="demo"
        >
          <div
            class="bg-ink absolute -top-[15px] left-1/2 z-[4] -translate-x-1/2 whitespace-nowrap rounded-full px-[13px] py-2 font-mono text-[9px] tracking-[.12em] text-white"
          >
            LIVE DEMO
          </div>
          <IframeWindow
            url="/app/index.html"
            title={t.demo.iframeTitle}
            tabTitle={t.demo.tabTitle}
          />
        </div>
      </section>

      <section
        class="mx-auto max-w-[1300px] px-12 py-[130px] max-md:px-6 max-md:py-[90px]"
        id="features"
      >
        <div class={sectionKicker}>WHY BROWSERTAB / 01</div>
        <div
          class="grid grid-cols-[1.4fr_.6fr] items-end gap-[100px] py-12 pb-[70px] max-md:grid-cols-1 max-md:gap-[30px] max-sm:pb-[50px]"
        >
          <h2
            class="m-0 text-[clamp(48px,6vw,82px)] font-normal leading-[1.02] tracking-[-.06em] max-sm:text-[46px]"
          >
            {t.features.title1}<br /><span class="text-brand"
              >{t.features.title2}</span
            >
          </h2>
          <div>
            <p class="text-muted text-[15px] leading-[1.8]">
              {t.features.description}
            </p><a
              class="border-ink mt-[18px] inline-flex gap-10 border-b pb-1.5 text-[13px] font-semibold"
              href="#download">{t.features.link} <span>→</span></a
            >
          </div>
        </div>

        <div class="border-line grid grid-cols-3 border-y max-md:grid-cols-1">
          <article
            class="border-line relative border-r px-9 pb-[42px] pt-[38px] max-md:border-b max-md:border-r-0"
          >
            <span
              class="absolute right-6 top-[22px] font-mono text-[10px] text-[#aaa59f]"
              >01</span
            ><div
              class="mb-9 grid size-[58px] place-items-center rounded-full border border-[#c9c5bf]"
              aria-hidden="true"
            >
              <span
                class="border-brand col-start-1 row-start-1 size-[22px] rotate-45 rounded-[5px] border-2"
              ></span><i
                class="bg-ink col-start-1 row-start-1 size-2 rounded-full"></i>
            </div><h3 class="mb-3 text-[19px] font-semibold tracking-[-.03em]">
              {t.features.items[0][0]}
            </h3><p class="text-muted max-w-[280px] text-[13px] leading-[1.75]">
              {t.features.items[0][1]}
            </p>
          </article>
          <article
            class="border-line relative border-r px-9 pb-[42px] pt-[38px] max-md:border-b max-md:border-r-0"
          >
            <span
              class="absolute right-6 top-[22px] font-mono text-[10px] text-[#aaa59f]"
              >02</span
            ><div
              class="mb-9 grid size-[58px] place-items-center rounded-full border border-[#c9c5bf]"
              aria-hidden="true"
            >
              <span
                class="border-ink col-start-1 row-start-1 size-[22px] rounded-full border-2"
              ></span><i
                class="bg-brand col-start-1 row-start-1 size-3 rounded-full"
              ></i>
            </div><h3 class="mb-3 text-[19px] font-semibold tracking-[-.03em]">
              {t.features.items[1][0]}
            </h3><p class="text-muted max-w-[280px] text-[13px] leading-[1.75]">
              {t.features.items[1][1]}
            </p>
          </article>
          <article class="relative px-9 pb-[42px] pt-[38px]">
            <span
              class="absolute right-6 top-[22px] font-mono text-[10px] text-[#aaa59f]"
              >03</span
            ><div
              class="mb-9 grid size-[58px] place-items-center rounded-full border border-[#c9c5bf]"
              aria-hidden="true"
            >
              <span class="flex h-5 w-6 flex-col justify-between">
                <i class="bg-brand h-0.5 w-full"></i>
                <i class="bg-ink h-0.5 w-full"></i>
                <i class="h-0.5 w-full bg-[#aaa59f]"></i>
              </span>
            </div><h3 class="mb-3 text-[19px] font-semibold tracking-[-.03em]">
              {t.features.items[2][0]}
            </h3><p class="text-muted max-w-[280px] text-[13px] leading-[1.75]">
              {t.features.items[2][1]}
            </p>
          </article>
        </div>
      </section>

      <section
        class="bg-ink grid min-h-[670px] scroll-mt-[76px] grid-cols-2 text-white max-md:scroll-mt-[66px] max-md:grid-cols-1"
        id="opensource"
      >
        <div
          class="relative min-h-[550px] overflow-hidden border-r border-white/10 bg-[radial-gradient(circle_at_center,#30302d_0_2px,transparent_3px)] bg-[size:24px_24px] max-md:min-h-[420px] max-md:border-b max-md:border-r-0 max-sm:min-h-[330px]"
          aria-hidden="true"
        >
          <span
            class="text-brand absolute left-[19%] top-[8%] font-serif text-[380px] font-light leading-none max-sm:left-[10%] max-sm:text-[260px]"
            >{`{`}</span
          ><span
            class="bg-brand absolute left-1/2 top-1/2 size-[115px] -translate-x-1/2 -translate-y-1/2 rounded-full shadow-[0_0_0_18px_rgba(255,79,36,.12)]"
          ></span><span
            class="text-brand absolute right-[19%] top-[31%] font-serif text-[380px] font-light leading-none max-sm:right-[10%] max-sm:text-[260px]"
            >{`}`}</span
          >
        </div>
        <div
          class="flex flex-col justify-center px-[clamp(42px,7vw,110px)] py-20 max-sm:px-6 max-sm:py-[65px]"
        >
          <div class:list={[sectionKicker, "border-white/15 text-[#888]"]}>
            OPEN SOURCE / 02
          </div>
          <h2
            class="mb-0 mt-[42px] text-[clamp(46px,5vw,72px)] font-normal leading-[1.02] tracking-[-.06em]"
          >
            {t.source.title1}<br />{t.source.title2}
          </h2>
          <p
            class="my-7 max-w-[500px] text-[15px] leading-[1.8] text-[#aaa7a2]"
          >
            {t.source.description}
          </p>
          <a
            class:list={[buttonBase, "text-ink self-start bg-white"]}
            href={placeholderUrl}>{t.source.link} <span>↗</span></a
          >
        </div>
      </section>

      <section
        class:list={[
          gridPaper,
          "relative overflow-hidden px-6 py-[130px] text-center max-sm:px-5 max-sm:py-[90px]",
        ]}
        id="download"
      >
        <div
          class="text-caption inline-flex items-center gap-2.5 font-mono text-[11px] uppercase tracking-[.12em]"
        >
          GET STARTED / 03
        </div>
        <h2
          class="mb-0 mt-[30px] text-[clamp(48px,6vw,82px)] font-normal leading-[1.02] tracking-[-.06em] max-sm:text-[46px]"
        >
          {t.download.title1}<br /><em class="text-brand not-italic"
            >{t.download.title2}</em
          >
        </h2>
        <p class="text-muted mb-[34px] mt-6 text-[15px]">
          {t.download.description}
        </p>
        <div class="flex justify-center gap-3.5 max-sm:flex-col">
          <a
            class="hover:border-brand grid min-w-[250px] grid-cols-[38px_1fr_auto] items-center gap-3.5 rounded-[14px] border border-[#ccc8c1] bg-white/80 p-4 text-left transition hover:-translate-y-0.5 hover:shadow-[0_14px_30px_rgba(30,20,15,.08)] max-sm:mx-auto max-sm:w-full max-sm:min-w-0 max-sm:max-w-[360px]"
            href={placeholderUrl}
            ><span
              class="size-9 rounded-full bg-[conic-gradient(#e94235_0_33%,#fabb05_0_66%,#34a853_0)] shadow-[inset_0_0_0_9px_#4285f4]"
              aria-hidden="true"></span><span
              ><small class="mb-1 block text-[9px] text-[#88837d]"
                >{t.download.storeLabel}</small
              ><strong class="text-sm">Google Chrome</strong></span
            ><b class="font-normal text-[#999]">↗</b></a
          >
          <a
            class="hover:border-brand grid min-w-[250px] grid-cols-[38px_1fr_auto] items-center gap-3.5 rounded-[14px] border border-[#ccc8c1] bg-white/80 p-4 text-left transition hover:-translate-y-0.5 hover:shadow-[0_14px_30px_rgba(30,20,15,.08)] max-sm:mx-auto max-sm:w-full max-sm:min-w-0 max-sm:max-w-[360px]"
            href={placeholderUrl}
            ><span
              class="grid size-9 place-items-center rounded-full bg-gradient-to-br from-[#0aa5f5] to-[#0dcc93] font-serif text-2xl font-bold text-white"
              aria-hidden="true">e</span
            ><span
              ><small class="mb-1 block text-[9px] text-[#88837d]"
                >{t.download.storeLabel}</small
              ><strong class="text-sm">Microsoft Edge</strong></span
            ><b class="font-normal text-[#999]">↗</b></a
          >
        </div>
      </section>
    </main>

    <footer
      class="border-line grid min-h-40 grid-cols-[1fr_auto_1fr] items-center gap-[30px] border-t bg-[#f1efe9] px-[clamp(24px,6vw,96px)] py-[42px] text-xs max-md:grid-cols-[1fr_auto] max-sm:flex max-sm:flex-wrap max-sm:justify-between"
    >
      <a
        class="inline-flex w-max items-center gap-3 font-bold tracking-[-.03em]"
        href="#top"
        ><span
          class="bg-brand grid size-7 place-items-center rounded-lg text-xs text-white"
          aria-hidden="true">B</span
        ><span>BrowserTab</span></a
      >
      <p class="text-muted max-md:hidden">{t.footerTagline}</p>
      <div
        class="flex gap-6 justify-self-end max-sm:w-full max-sm:justify-start"
      >
        <a class="hover:text-brand" href={placeholderUrl}>GitHub</a><a
          class="hover:text-brand"
          href="#features">{t.nav.features}</a
        ><a class="hover:text-brand" href="#demo">{t.nav.demo}</a><a
          class="hover:text-brand"
          href={languageUrl}>{languageLabel}</a
        >
      </div>
      <small
        class="border-line col-span-full w-full border-t pt-5 text-[#aaa59e]"
        >© 2026 BrowserTab · Open source with care.</small
      >
    </footer>
  </body>
</html>
