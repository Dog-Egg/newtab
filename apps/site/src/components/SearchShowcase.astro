---
import Search from "@lucide/astro/icons/search";
import Bookmark from "@lucide/astro/icons/bookmark";
import PenLine from "@lucide/astro/icons/pen-line";
import Palette from "@lucide/astro/icons/palette";

interface Shortcut {
  name: string;
  host: string;
  tone: "orange" | "teal" | "purple";
}

interface Props {
  query: string;
  engineHost: string;
  searchAction: string;
  groupLabel: string;
  shortcuts: readonly Shortcut[];
  ariaLabel: string;
}

const { query, engineHost, searchAction, groupLabel, shortcuts, ariaLabel } =
  Astro.props;
const shortcutIcons = {
  orange: Bookmark,
  teal: PenLine,
  purple: Palette,
};
---

<div
  class="relative w-full overflow-hidden rounded-[26px] border border-[#d7d2ca] bg-[#fdfcf9] shadow-[0_30px_70px_rgba(37,31,24,.14)] max-sm:rounded-[20px]"
  role="img"
  aria-label={ariaLabel}
>
  <div
    class="flex h-[92px] items-center gap-5 border-b border-[#dedad4] px-8 max-sm:h-[68px] max-sm:gap-3 max-sm:px-5"
  >
    <Search class="size-7 shrink-0 max-sm:size-5" stroke-width="1.8" aria-hidden="true" />
    <span class="h-10 w-px bg-[#dedad4] max-sm:h-7" aria-hidden="true"></span>
    <span
      class="text-[34px] font-normal leading-none tracking-[-.035em] text-ink max-sm:text-[25px]"
      >{query}</span
    >
    <span
      class="ml-[-12px] h-10 w-[2px] bg-brand max-sm:ml-[-7px] max-sm:h-7"
      aria-hidden="true"
    ></span>
  </div>

  <div class="px-[18px] pb-5 pt-[18px] max-sm:px-2.5 max-sm:pb-3 max-sm:pt-2.5">
    <div
      class="flex min-h-[82px] items-center gap-5 rounded-[18px] bg-brand/[.065] px-6 max-sm:min-h-[64px] max-sm:gap-3 max-sm:rounded-[14px] max-sm:px-3.5"
    >
      <span
        class="grid size-12 shrink-0 place-items-center rounded-full bg-brand text-white shadow-[0_8px_20px_rgba(255,79,36,.2)] max-sm:size-9"
        aria-hidden="true"
      >
        <Search class="size-5 max-sm:size-4" stroke-width="2" />
      </span>
      <strong
        class="min-w-0 flex-1 truncate text-[22px] font-semibold tracking-[-.025em] text-ink max-sm:text-[16px]"
        >{engineHost}</strong
      >
      <span
        class="inline-flex shrink-0 items-center gap-2 rounded-[12px] border border-brand/35 bg-white/70 px-4 py-3 text-[13px] font-semibold text-brand max-sm:px-2.5 max-sm:py-2 max-sm:text-[11px]"
      >
        <Search class="size-4" stroke-width="2" aria-hidden="true" />
        <span>{searchAction}</span>
      </span>
    </div>

    <div
      class="flex items-center gap-3 px-6 pb-2 pt-6 font-mono text-[10px] uppercase tracking-[.13em] text-[#79736c] max-sm:px-3.5 max-sm:pb-1 max-sm:pt-4 max-sm:text-[9px]"
    >
      <Bookmark class="size-4" stroke-width="1.8" aria-hidden="true" />
      {groupLabel}
    </div>

    <div class="pl-[34px] max-sm:pl-2">
      {
        shortcuts.map((shortcut) => {
          const ShortcutIcon = shortcutIcons[shortcut.tone];
          return (
          <div
            class:list={[
              "grid min-h-[74px] grid-cols-[44px_1fr_auto] items-center gap-4 border-b border-[#e5e1db] pr-6 last:border-b-0 max-sm:min-h-[58px] max-sm:grid-cols-[34px_1fr_auto] max-sm:gap-2.5 max-sm:pr-3",
            ]}
          >
            <span
              class:list={[
                "shortcut-icon grid size-10 place-items-center rounded-[11px] max-sm:size-8 max-sm:rounded-[9px]",
                `shortcut-icon-${shortcut.tone}`,
              ]}
              aria-hidden="true"
            >
              <ShortcutIcon class="size-5 max-sm:size-4" stroke-width="1.9" />
            </span>
            <strong class="truncate text-[19px] font-medium tracking-[-.025em] text-ink max-sm:text-[14px]">
              {shortcut.name}
            </strong>
            <span class="truncate text-[14px] text-[#6f6962] max-sm:max-w-[105px] max-sm:text-[11px]">
              {shortcut.host}
            </span>
          </div>
          );
        })
      }
    </div>
  </div>
</div>

<style>
  .shortcut-icon-orange {
    color: #ff4f24;
    background: #ffebe2;
  }

  .shortcut-icon-teal {
    color: #167b75;
    background: #e5f1ee;
  }

  .shortcut-icon-purple {
    color: #6741e8;
    background: #ece9ff;
  }

</style>
